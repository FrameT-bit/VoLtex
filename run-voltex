#!/usr/bin/env bash
set -euo pipefail

if command -v realpath >/dev/null 2>&1; then
  RESOLVED="$(realpath "${BASH_SOURCE[0]}")"
elif command -v readlink >/dev/null 2>&1 && readlink -f "${BASH_SOURCE[0]}" >/dev/null 2>&1; then
  RESOLVED="$(readlink -f "${BASH_SOURCE[0]}")"
else
  RESOLVED="${BASH_SOURCE[0]}"
fi
APP_DIR="${VOLTEX_APP_DIR:-$(cd "$(dirname "$RESOLVED")" && pwd)}"
STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}"
LOG_DIR="$STATE_ROOT/voltex"
LOG_FILE="$LOG_DIR/launcher.log"

export GDK_BACKEND="${VOLTEX_GDK_BACKEND:-x11}"

mkdir -p "$LOG_DIR"
chmod 700 "$LOG_DIR" 2>/dev/null || true
touch "$LOG_FILE"
chmod 600 "$LOG_FILE" 2>/dev/null || true

show_error() {
  local message="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title="VoLtex" --text="$message" 2>/dev/null || true
  elif command -v kdialog >/dev/null 2>&1; then
    kdialog --error "$message" --title "VoLtex" 2>/dev/null || true
  elif command -v notify-send >/dev/null 2>&1; then
    notify-send "VoLtex" "$message" 2>/dev/null || true
  fi
}

crash_dialog() {
  if ! command -v zenity >/dev/null 2>&1; then
    return
  fi
  local msg="VoLtex encountered an error.\n\nDetails: $LOG_FILE"
  if zenity --question --title="VoLtex" --width=400 \
    --text="$msg" \
    --ok-label="Report Issue" --cancel-label="Close" 2>/dev/null; then
    xdg-open "https://github.com/FrameT-bit/VoLtex/issues/new" &
  fi
}

fail_start() {
  local message="$1"
  echo "$message" >>"$LOG_FILE"
  show_error "$message"
  printf '%s\n' "$message" >&2
  crash_dialog &
  exit 1
}

if [[ -x "$APP_DIR/.venv/bin/python" ]]; then
  PYTHON="$APP_DIR/.venv/bin/python"
else
  fail_start "VoLtex: Python environment not found at $APP_DIR/.venv\nRun: bash \"$APP_DIR/install\""
fi

if ! missing="$("$PYTHON" -c 'import importlib.util; missing = [name for name in ("flask", "webview", "keyring") if importlib.util.find_spec(name) is None]; print(", ".join(missing)); raise SystemExit(1 if missing else 0)' 2>/dev/null)"; then
  fail_start "VoLtex: missing dependencies (${missing:-unknown})\nRun: bash \"$APP_DIR/install\""
fi

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"

check_auto_update() {
  local config="$CONFIG_DIR/voltex/config"
  [[ -f "$config" ]] || return
  grep -q "auto_update=true" "$config" || return

  local result
  result=$("$PYTHON" -m voltex.main --check-update 2>/dev/null) || true
  [[ "$result" == *"Update available"* ]] || return

  if zenity --question --title="VoLtex" --width=350 \
    --text="A new version of VoLtex is available.\n\nUpdate now?" \
    --ok-label="Update" --cancel-label="Skip" 2>/dev/null; then
    "$PYTHON" -m voltex.main --update 2>/dev/null
  elif zenity --question --title="VoLtex" --width=350 \
    --text="Stop checking for updates on launch?" \
    --ok-label="Yes" --cancel-label="No" 2>/dev/null; then
    sed -i '/auto_update=true/d' "$config"
  fi
}

check_auto_update

cd "$APP_DIR"

if [[ -t 1 ]]; then
  exec "$PYTHON" -m voltex.main "$@"
fi

"$PYTHON" -m voltex.main "$@" >>"$LOG_FILE" 2>&1 || {
  status=$?
  message="VoLtex could not start. Details were written to $LOG_FILE"
  echo "$message" >>"$LOG_FILE"
  show_error "$message"
  crash_dialog &
  exit "$status"
}
